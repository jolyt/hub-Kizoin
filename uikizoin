local function cleanAssetId(id)
    return tostring(id or ""):gsub("%D", "")
end

local function toRobloxImage(id)
    local cleaned = cleanAssetId(id)
    if cleaned == "" then
        return ""
    end
    return ("rbxthumb://type=Asset&id=%s&w=420&h=420"):format(cleaned)
end

local LOGO_ID = toRobloxImage(RAW_LOGO_ID)

local function applyLogo(img, id, color, transparency)
    img.BackgroundTransparency = 1
    img.Image = toRobloxImage(id or RAW_LOGO_ID)
    img.ScaleType = Enum.ScaleType.Fit
    if color then
        img.ImageColor3 = color
    end
    if transparency ~= nil then
        img.ImageTransparency = transparency
    end
end

local function playSound(id, vol, pitch)
    pcall(function()
        local s = Instance.new("Sound")
        s.SoundId = id
        s.Volume = vol or 0.5
        s.PlaybackSpeed = pitch or 1
        s.Parent = SoundService
        s:Play()
        Debris:AddItem(s, 3)
    end)
end

local function tween(ins, props, time, style, dir)
    pcall(function()
        TweenService:Create(
            ins,
            TweenInfo.new(
                time or 0.2,
                style or Enum.EasingStyle.Quart,
                dir or Enum.EasingDirection.InOut
            ),
            props
        ):Play()
    end)
end

local function tp(ins, pos, time, style, dir)
    tween(ins, {Position = pos}, time, style, dir)
end

local function spring(ins, props, time)
    tween(ins, props, time or 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

local function pulseStroke(stroke, minT, maxT, spd)
    task.spawn(function()
        local grow = true
        while stroke and stroke.Parent do
            tween(stroke, {Thickness = grow and maxT or minT}, spd or 0.8, Enum.EasingStyle.Sine)
            grow = not grow
            task.wait(spd or 0.8)
        end
    end)
end

