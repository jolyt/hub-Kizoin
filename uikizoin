                    tween(track, {BackgroundColor3 = Color3.fromRGB(50, 30, 70)}, 0.15)
                end
            end
            updateSwitch()

            local function toggle()
                mode = not mode
                updateSwitch()
                playSound(SND.toggle, 0.3, mode and 1.15 or 0.9)
                if callback then pcall(callback, mode) end
            end
            track.MouseButton1Click:Connect(toggle)
            thumb.MouseButton1Click:Connect(toggle)
