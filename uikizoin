            btn.Size = UDim2.new(0, 418, 0, 42)
            btn.ZIndex = 2
            btn.Font = Enum.Font.GothamBold
            btn.Text = name2 or ""
            btn.TextColor3 = C.text
            btn.TextSize = 17
            btn.AutoButtonColor = false
            btn.ClipsDescendants = true
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

            local bst = Instance.new("UIStroke", btn)
            bst.Color = C.accentDark
            bst.Thickness = 1

            local bsc = Instance.new("UIScale", btn)
            bsc.Scale = 1

            local glow = Instance.new("ImageLabel", btn)
            glow.AnchorPoint = Vector2.new(0.5, 0.5)
            glow.BackgroundTransparency = 1
            glow.Position = UDim2.new(0.5, 0, 0.5, 0)
            glow.Size = UDim2.new(1.15, 0, 2.2, 0)
            glow.Image = "rbxassetid://313486536"
            glow.ImageColor3 = C.accent
            glow.ImageTransparency = 0.92
            glow.ZIndex = 1

            attachShine(btn)

            btn.MouseEnter:Connect(function()
                tween(btn, {BackgroundColor3 = C.accentDark}, 0.18)
                tween(bst, {Color = C.accent}, 0.18)
                tween(glow, {ImageTransparency = 0.82}, 0.18)
            end)

            btn.MouseLeave:Connect(function()
                tween(btn, {BackgroundColor3 = C.button}, 0.18)
                tween(bst, {Color = C.accentDark}, 0.18)
                tween(glow, {ImageTransparency = 0.92}, 0.18)
                spring(bsc, {Scale = 1}, 0.12)
            end)

            btn.MouseButton1Down:Connect(function()
                tween(bsc, {Scale = 0.984}, 0.06, Enum.EasingStyle.Quad)
            end)

            btn.MouseButton1Up:Connect(function()
                spring(bsc, {Scale = 1}, 0.14)
            end)

            if callback then
                btn.MouseButton1Click:Connect(function()
                    pcall(function()
                        local Mouse = game:GetService("Players").LocalPlayer:GetMouse()
                        local rx = Mouse.X - btn.AbsolutePosition.X
                        local ry = Mouse.Y - btn.AbsolutePosition.Y

                        local ripple = Instance.new("Frame", btn)
                        ripple.BackgroundColor3 = C.white
                        ripple.BackgroundTransparency = 0.82
                        ripple.BorderSizePixel = 0
                        ripple.AnchorPoint = Vector2.new(0.5, 0.5)
                        ripple.Position = UDim2.new(0, rx, 0, ry)
                        ripple.Size = UDim2.new(0, 0, 0, 0)
                        ripple.ZIndex = btn.ZIndex + 2
                        Instance.new("UICorner", ripple).CornerRadius = UDim.new(1, 0)

                        TweenService:Create(
                            ripple,
                            TweenInfo.new(0.55, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                            {
                                Size = UDim2.new(0, btn.AbsoluteSize.X * 1.6, 0, btn.AbsoluteSize.X * 1.6),
                                BackgroundTransparency = 1
                            }
                        ):Play()

                        Debris:AddItem(ripple, 0.65)
                    end)

                    playSound(POPUP_SND, 0.3, 1.05)
                    tween(btn, {TextTransparency = 0.4}, 0.05)
                    task.wait(0.05)
                    tween(btn, {TextTransparency = 0}, 0.08)
                    pcall(callback)
                end)
            end
        end

        function sec:Label(name2)
            local lbl = Instance.new("TextLabel", wam)
            lbl.BackgroundTransparency = 1
            lbl.Size = UDim2.new(0, 418, 0, 34)
            lbl.Font = Enum.Font.Gotham
            lbl.TextColor3 = C.subtext
            lbl.TextSize = 17
            lbl.TextWrapped = true
            lbl.Text = "  " .. (name2 or "")
            lbl.TextXAlignment = Enum.TextXAlignment.Left
        end

        function sec:Switch(name2, defaultmode, callback)
            local mode = defaultmode or false

            local row = Instance.new("TextLabel", wam)
            row.BackgroundColor3 = C.button
            row.Size = UDim2.new(0, 418, 0, 42)
            row.Font = Enum.Font.GothamBold
            row.Text = "  " .. (name2 or "")
            row.TextColor3 = C.text
            row.TextSize = 17
            row.TextWrapped = true
            row.TextXAlignment = Enum.TextXAlignment.Left
            Instance.new("UICorner", row).CornerRadius = UDim.new(0, 9)

            local track = Instance.new("TextButton", row)
            track.Position = UDim2.new(0.832, 0, 0.12, 0)
            track.Size = UDim2.new(0, 70, 0, 32)
            track.Text = ""
            track.AutoButtonColor = false
            Instance.new("UICorner", track).CornerRadius = UDim.new(5, 0)

            local thumb = Instance.new("TextButton", track)
            thumb.BackgroundColor3 = C.white
            thumb.Size = UDim2.new(0, 30, 0, 30)
            thumb.AutoButtonColor = false
            thumb.Text = ""
            Instance.new("UICorner", thumb).CornerRadius = UDim.new(5, 0)

            local function updateSwitch()
                if mode then
                    thumb:TweenPosition(UDim2.new(0, 39, 0, 1), "In", "Sine", 0.15, true)
                    tween(track, {BackgroundColor3 = C.accent}, 0.15)
                else
                    thumb:TweenPosition(UDim2.new(0, 1, 0, 1), "In", "Sine", 0.15, true)
                    tween(track, {BackgroundColor3 = Color3.fromRGB(50, 30, 70)}, 0.15)
                end
            end

            updateSwitch()

            local function toggle()
                mode = not mode
                updateSwitch()
                playSound(POPUP_SND, 0.25, mode and 1.2 or 0.9)
                if callback then
                    pcall(callback, mode)
                end
            end

            track.MouseButton1Click:Connect(toggle)
            thumb.MouseButton1Click:Connect(toggle)
        end

        function sec:TextField(name2, placeholder, callback)
            local row = Instance.new("TextLabel", wam)
            row.BackgroundColor3 = C.button
            row.Size = UDim2.new(0, 418, 0, 42)
            row.Font = Enum.Font.GothamBold
            row.Text = "  " .. (name2 or "")
            row.TextColor3 = C.text
            row.TextSize = 17
            row.TextWrapped = true
            row.TextXAlignment = Enum.TextXAlignment.Left
            Instance.new("UICorner", row).CornerRadius = UDim.new(0, 9)

            local inputBg = Instance.new("Frame", row)
            inputBg.BackgroundColor3 = Color3.fromRGB(20, 10, 35)
            inputBg.Position = UDim2.new(0.44, 0, 0.1, 0)
            inputBg.Size = UDim2.new(0, 230, 0, 32)
            Instance.new("UICorner", inputBg).CornerRadius = UDim.new(0, 9)

            local inputStroke = Instance.new("UIStroke", inputBg)
            inputStroke.Color = C.accentDark
            inputStroke.Thickness = 1

            local tb = Instance.new("TextBox", inputBg)
            tb.BackgroundTransparency = 1
            tb.ClipsDescendants = true
            tb.Position = UDim2.new(0.04, 0, 0, 0)
            tb.Size = UDim2.new(0.92, 0, 1, 0)
            tb.ClearTextOnFocus = false
            tb.Font = Enum.Font.Gotham
            tb.PlaceholderColor3 = C.subtext
            tb.PlaceholderText = placeholder or "Type..."
            tb.Text = ""
            tb.TextColor3 = C.text
            tb.TextSize = 15
            tb.TextXAlignment = Enum.TextXAlignment.Left

            tb.Focused:Connect(function()
                tween(inputStroke, {Color = C.accent}, 0.2)
            end)

            tb.FocusLost:Connect(function()
                tween(inputStroke, {Color = C.accentDark}, 0.2)
                if callback then
                    pcall(callback, tb.Text)
                end
            end)
        end

        sideBtn.MouseButton1Click:Connect(function()
            sec:Select()
        end)

        return sec
    end

    return window
end

return lib
