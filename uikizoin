local function playSound(id, vol, pitch)
    pcall(function()
        local s = Instance.new("Sound")
        s.SoundId = id
        s.Volume = vol or 0.5
        s.PlaybackSpeed = pitch or 1
        s.Parent = SoundService
        s:Play()
        Debris:AddItem(s, 3)
    end)
end

local function tp(ins, pos, time, style, dir)
    pcall(function()
        TweenService:Create(ins, TweenInfo.new(time, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.InOut), {Position = pos}):Play()
    end)
end

local function tween(ins, props, time, style, dir)
    pcall(function()
        TweenService:Create(ins, TweenInfo.new(time or 0.2, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.InOut), props):Play()
    end)
end

local function spring(ins, props, time)
    tween(ins, props, time or 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

local function pulseStroke(stroke, minT, maxT, speed)
    task.spawn(function()
        local grow = true
        while stroke and stroke.Parent do
            tween(stroke, {Thickness = grow and maxT or minT}, speed or 0.8, Enum.EasingStyle.Sine)
            grow = not grow
            task.wait(speed or 0.8)
        end
    end)
end

local function attachShine(gui)
    pcall(function()
        local sh = Instance.new("Frame")
        sh.Name = "ShineHolder"
        sh.Parent = gui
        sh.BackgroundTransparency = 1
        sh.ClipsDescendants = true
        sh.Size = UDim2.fromScale(1, 1)
        sh.ZIndex = gui.ZIndex + 1
        local shine = Instance.new("Frame")
        shine.Parent = sh
        shine.BackgroundColor3 = C.white
        shine.BackgroundTransparency = 0.86
        shine.BorderSizePixel = 0
        shine.Position = UDim2.new(-1.2, 0, -0.2, 0)
        shine.Size = UDim2.new(0.35, 0, 1.4, 0)
        shine.Rotation = 16
        shine.ZIndex = gui.ZIndex + 1
        local grad = Instance.new("UIGradient", shine)
        grad.Transparency = NumberSequence.new{
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(0.5, 0.15),
            NumberSequenceKeypoint.new(1, 1),
        }
        gui.MouseEnter:Connect(function()
            shine.Position = UDim2.new(-1.2, 0, -0.2, 0)
            tween(shine, {Position = UDim2.new(1.2, 0, -0.2, 0)}, 0.55, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        end)
    end)
end

-- Blur
local blur = Lighting:FindFirstChild("KizoinHubBlur")
if not blur then
    blur = Instance.new("BlurEffect")
    blur.Name = "KizoinHubBlur"
    blur.Size = 0
    blur.Enabled = false
    blur.Parent = Lighting
end

local function setBlur(amount, time)
    pcall(function()
        blur.Enabled = true
        tween(blur, {Size = amount}, time or 0.2, Enum.EasingStyle.Quart)
        if amount <= 0 then
            task.delay((time or 0.2) + 0.05, function()
                if blur and blur.Parent then blur.Enabled = false end
            end)
        end
    end)
end

