    function window:Divider(name)
        local div = Instance.new("TextLabel")
        div.Parent = sidebar
        div.BackgroundTransparency = 1
        div.Size = UDim2.new(0, 226, 0, 26)
        div.Font = Enum.Font.GothamBold
