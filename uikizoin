        div.TextSize = 14
        div.TextWrapped = true
        div.TextXAlignment = Enum.TextXAlignment.Left
        div.TextYAlignment = Enum.TextYAlignment.Bottom
    end

    function window:Section(name)
        local sideBtn = Instance.new("TextButton")
        sideBtn.Parent = sidebar
        sideBtn.BackgroundColor3 = C.accent
        sideBtn.BackgroundTransparency = 1
        sideBtn.Size = UDim2.new(0, 226, 0, 37)
        sideBtn.ZIndex = 2
        sideBtn.AutoButtonColor = false
        sideBtn.Font = Enum.Font.GothamBold
        sideBtn.Text = "  " .. name
        sideBtn.TextColor3 = C.subtext
        sideBtn.TextSize = 18
        sideBtn.TextXAlignment = Enum.TextXAlignment.Left

        Instance.new("UICorner", sideBtn).CornerRadius = UDim.new(0, 9)
        table.insert(sections, sideBtn)

        -- Hover sidebar
        sideBtn.MouseEnter:Connect(function()
            if sideBtn.BackgroundTransparency ~= 0 then
                tween(sideBtn, {BackgroundTransparency = 0.7}, 0.2)
            end
        end)
        sideBtn.MouseLeave:Connect(function()
            if sideBtn.BackgroundTransparency ~= 0 then
                tween(sideBtn, {BackgroundTransparency = 1}, 0.2)
            end
        end)

        local workareamain = Instance.new("ScrollingFrame")
        workareamain.Parent = workarea
        workareamain.Active = true
        workareamain.BackgroundTransparency = 1
        workareamain.BorderSizePixel = 0
        workareamain.Position = UDim2.new(0.039, 0, 0.096, 0)
        workareamain.Size = UDim2.new(0, 422, 0, 512)
        workareamain.ZIndex = 3
        workareamain.CanvasSize = UDim2.new(0, 0, 0, 0)
        workareamain.AutomaticCanvasSize = "Y"
        workareamain.ScrollBarThickness = 2
        workareamain.ScrollBarImageColor3 = C.accent
        workareamain.Visible = false

        local waLayout = Instance.new("UIListLayout")
        waLayout.Parent = workareamain
        waLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        waLayout.SortOrder = Enum.SortOrder.LayoutOrder
        waLayout.Padding = UDim.new(0, 5)

        table.insert(workareas, workareamain)

        local sec = {}

        function sec:Select()
            for _, v in next, sections do
                v.BackgroundTransparency = 1
                v.TextColor3 = C.subtext
            end
            sideBtn.BackgroundTransparency = 0
            sideBtn.TextColor3 = C.white
            for _, v in next, workareas do
                v.Visible = false
            end
            workareamain.Visible = true
        end

        function sec:Divider(name)
            local div = Instance.new("TextLabel")
            div.Parent = workareamain
            div.BackgroundTransparency = 1
            div.Size = UDim2.new(0, 418, 0, 45)
            div.Font = Enum.Font.GothamBold
            div.Text = name
            div.TextColor3 = C.text
            div.TextSize = 22
            div.TextWrapped = true
            div.TextXAlignment = Enum.TextXAlignment.Left
            div.TextYAlignment = Enum.TextYAlignment.Bottom

            local divLine = Instance.new("Frame")
            divLine.Parent = div
            divLine.BackgroundColor3 = C.accentDark
            divLine.BorderSizePixel = 0
            divLine.Position = UDim2.new(0, 0, 1, -2)
            divLine.Size = UDim2.new(1, 0, 0, 1)
        end

        function sec:Button(name, callback)
            local btn = Instance.new("TextButton")
            btn.Parent = workareamain
            btn.BackgroundColor3 = C.button
            btn.Size = UDim2.new(0, 418, 0, 40)
            btn.ZIndex = 2
            btn.Font = Enum.Font.GothamBold
            btn.Text = name
            btn.TextColor3 = C.text
            btn.TextSize = 18
            btn.AutoButtonColor = false
            btn.ClipsDescendants = true

            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 9)
            local btnStroke = Instance.new("UIStroke", btn)
            btnStroke.Color = C.accentDark
            btnStroke.Thickness = 1

            btn.MouseEnter:Connect(function()
                tween(btn, {BackgroundColor3 = C.accentDark}, 0.2)
                tween(btnStroke, {Color = C.accent}, 0.2)
            end)
            btn.MouseLeave:Connect(function()
                tween(btn, {BackgroundColor3 = C.button}, 0.2)
                tween(btnStroke, {Color = C.accentDark}, 0.2)
            end)

            if callback then
                btn.MouseButton1Click:Connect(function()
                    local Mouse = game:GetService("Players").LocalPlayer:GetMouse()
                    local relativeX = Mouse.X - btn.AbsolutePosition.X
                    local relativeY = Mouse.Y - btn.AbsolutePosition.Y
                    
                    local circle = Instance.new("Frame")
                    circle.Parent = btn
                    circle.BackgroundColor3 = C.white
                    circle.BackgroundTransparency = 0.8
                    circle.BorderSizePixel = 0
                    circle.AnchorPoint = Vector2.new(0.5, 0.5)
                    circle.Position = UDim2.new(0, relativeX, 0, relativeY)
                    circle.Size = UDim2.new(0, 0, 0, 0)
                    circle.ZIndex = btn.ZIndex + 1
                    
                    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)
                    
                    local t = game:GetService("TweenService"):Create(circle, TweenInfo.new(0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                        Size = UDim2.new(0, btn.AbsoluteSize.X * 1.5, 0, btn.AbsoluteSize.X * 1.5),
                        BackgroundTransparency = 1
                    })
                    t:Play()
                    game:GetService("Debris"):AddItem(circle, 1)

                    coroutine.wrap(function()
                        tween(btn, {TextTransparency = 0.5}, 0.06)
                        task.wait(0.06)
                        tween(btn, {TextTransparency = 0}, 0.06)
                    end)()

                    callback()
                end)
            end
        end

        function sec:Label(name)
            local lbl = Instance.new("TextLabel")
            lbl.Parent = workareamain
            lbl.BackgroundTransparency = 1
            lbl.Size = UDim2.new(0, 418, 0, 37)
            lbl.Font = Enum.Font.Gotham
            lbl.TextColor3 = C.subtext
            lbl.TextSize = 18
            lbl.TextWrapped = true
            lbl.Text = "  " .. name
            lbl.TextXAlignment = Enum.TextXAlignment.Left
        end

        function sec:Switch(name, defaultmode, callback)
            local mode = defaultmode
            local row = Instance.new("TextLabel")
            row.Parent = workareamain
            row.BackgroundColor3 = C.button
            row.BackgroundTransparency = 0
            row.Size = UDim2.new(0, 418, 0, 40)
            row.Font = Enum.Font.GothamBold
            row.Text = "  " .. name
            row.TextColor3 = C.text
            row.TextSize = 18
            row.TextWrapped = true
            row.TextXAlignment = Enum.TextXAlignment.Left
            Instance.new("UICorner", row).CornerRadius = UDim.new(0, 9)

            local track = Instance.new("TextButton")
            track.Parent = row
            track.Position = UDim2.new(0.832, 0, 0.1, 0)
            track.Size = UDim2.new(0, 70, 0, 32)
            track.Text = ""
            track.AutoButtonColor = false
            Instance.new("UICorner", track).CornerRadius = UDim.new(5, 0)

            local thumb = Instance.new("TextButton")
            thumb.Parent = track
            thumb.BackgroundColor3 = C.white
            thumb.Size = UDim2.new(0, 30, 0, 30)
            thumb.AutoButtonColor = false
            thumb.Text = ""
            Instance.new("UICorner", thumb).CornerRadius = UDim.new(5, 0)

            local function updateSwitch()
                if mode then
                    thumb:TweenPosition(UDim2.new(0, 39, 0, 1), "In", "Sine", 0.15, true)
                    tween(track, {BackgroundColor3 = C.accent}, 0.15)
                else
                    thumb:TweenPosition(UDim2.new(0, 1, 0, 1), "In", "Sine", 0.15, true)
                    tween(track, {BackgroundColor3 = Color3.fromRGB(50, 30, 70)}, 0.15)
                end
            end

            updateSwitch()

            local function toggle()
                mode = not mode
                updateSwitch()
                if callback then callback(mode) end
            end

            track.MouseButton1Click:Connect(toggle)
            thumb.MouseButton1Click:Connect(toggle)
        end

        function sec:TextField(name, placeholder, callback)
            local row = Instance.new("TextLabel")
            row.Parent = workareamain
            row.BackgroundColor3 = C.button
            row.Size = UDim2.new(0, 418, 0, 40)
            row.Font = Enum.Font.GothamBold
            row.Text = "  " .. name
            row.TextColor3 = C.text
            row.TextSize = 18
            row.TextWrapped = true
            row.TextXAlignment = Enum.TextXAlignment.Left
            Instance.new("UICorner", row).CornerRadius = UDim.new(0, 9)

            local inputBg = Instance.new("Frame")
            inputBg.Parent = row
            inputBg.BackgroundColor3 = Color3.fromRGB(20, 10, 35)
            inputBg.Position = UDim2.new(0.44, 0, 0.1, 0)
            inputBg.Size = UDim2.new(0, 230, 0, 32)
            Instance.new("UICorner", inputBg).CornerRadius = UDim.new(0, 9)
            local inputStroke = Instance.new("UIStroke", inputBg)
            inputStroke.Color = C.accentDark
            inputStroke.Thickness = 1

            local tb = Instance.new("TextBox")
            tb.Parent = inputBg
            tb.BackgroundTransparency = 1
            tb.ClipsDescendants = true
            tb.Position = UDim2.new(0.04, 0, 0, 0)
            tb.Size = UDim2.new(0.92, 0, 1, 0)
            tb.ClearTextOnFocus = false
            tb.Font = Enum.Font.Gotham
            tb.PlaceholderColor3 = C.subtext
            tb.PlaceholderText = placeholder or "Type..."
            tb.Text = ""
            tb.TextColor3 = C.text
            tb.TextSize = 16
            tb.TextXAlignment = Enum.TextXAlignment.Left

            tb.Focused:Connect(function()
                tween(inputStroke, {Color = C.accent}, 0.2)
            end)
            tb.FocusLost:Connect(function()
                tween(inputStroke, {Color = C.accentDark}, 0.2)
                if callback then callback(tb.Text) end
            end)
        end

        sideBtn.MouseButton1Click:Connect(function()
            sec:Select()
        end)

        return sec
    end

    return window
end

return lib
